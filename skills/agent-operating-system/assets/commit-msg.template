#!/bin/sh
set -e

if [ -x scripts/agent-standards-hook.sh ]; then
  scripts/agent-standards-hook.sh commit-msg "$1"
fi

if [ -x scripts/agent-verify.sh ]; then
  scripts/agent-verify.sh --commit-msg "$1"
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/agent-verify.ps1 -CommitMessageFile "$1"
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/agent-verify.ps1 -CommitMessageFile "$1"
fi
